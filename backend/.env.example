# 血浆游离血红蛋白检测系统 - 环境配置文件
# 作者: 哈雷酱大小姐 (￣▽￣)／

# ============ 应用配置 ============
APP_NAME=血浆游离血红蛋白检测系统
APP_VERSION=2.0.0
DEBUG=True

# ============ 数据库配置 ============
# PostgreSQL数据库连接
DATABASE_URL=postgresql://fhb_user:fhb_password@localhost:5432/fhb_detection

# 如果没有PostgreSQL，可以使用SQLite（开发环境）
# DATABASE_URL=sqlite:///./fhb_detection.db

# ============ Redis配置 ============
REDIS_URL=redis://localhost:6379/0

# ============ JWT配置 ============
SECRET_KEY=your-super-secret-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============ CORS配置 ============
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============ 文件存储配置 ============
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ============ 硬件配置 ============
SPECTROMETER_TYPE=simulated  # simulated 或 serial
SPECTROMETER_PORT=COM3
SPECTROMETER_BAUDRATE=9600

# ============ 监控配置 ============
ENABLE_MONITORING=True
PROMETHEUS_PORT=9090

# ============ 邮件配置（可选） ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=血浆检测系统<noreply@haire酱.tech>

# ============ 前端配置 ============
REACT_APP_API_URL=http://localhost:8000
REACT_APP_TITLE=血浆游离血红蛋白检测系统
